# DocMind configuration.
# Copy to .env — the defaults below run the full demo with ZERO paid API keys.

# --- Providers (independent; see docs/decisions.md) ---
# EMBEDDING_PROVIDER: local (fastembed, no key) | openai | hash (tests only)
EMBEDDING_PROVIDER=local
# LLM_PROVIDER: local (extractive answerer, no key) | openai | anthropic
LLM_PROVIDER=local

# --- OpenAI-compatible (also works for Ollama / LM Studio / vLLM via base URL) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic (generation only) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Security ---
JWT_SECRET=dev-secret-change-in-production
COOKIE_SECURE=false

# --- Infrastructure (compose overrides these for containers) ---
DATABASE_URL=postgresql+asyncpg://docmind:docmind@localhost:5432/docmind
REDIS_URL=redis://localhost:6379/0
UPLOAD_DIR=/data/uploads
